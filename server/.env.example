# Server environment
PORT=8080
GIN_MODE=debug

# MongoDB
MONGO_URI=mongodb://mongo:27017
MONGO_DB=connect

# Redis
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRY=24h
JWT_REFRESH_EXPIRY=720h

# Device limit
MAX_ACCOUNTS_PER_DEVICE=2

# Club limits
MAX_CLUBS_PER_USER=3
CLUB_WARN_INACTIVE_DAYS=60
CLUB_ARCHIVE_INACTIVE_DAYS=90
CLUB_DELETE_AFTER_ARCHIVE_DAYS=30

# Meetup limits
MAX_INVITES_PER_MEETUP=10
